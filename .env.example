# Copy to `.env` and fill in real values. NEVER commit real secrets — only the
# anon key and public URLs below are safe to expose; everything else is a secret.

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key            # public (safe in the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key     # SECRET — full DB access, server only
SUPABASE_JWT_SECRET=your-supabase-jwt-secret        # SECRET — from Supabase API settings

# Redis
REDIS_URL=redis://localhost:6379

# Server
# Production: API_BASE_URL=https://api.usesincerely.com
#             CLIENT_URL=https://usesincerely.com
PORT=3001
API_BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# Tracking (open/click links embedded in sent emails — must be a domain you own)
# Production: TRACKING_BASE_URL=https://api.usesincerely.com
TRACKING_BASE_URL=http://localhost:3001
TRACKING_SECRET=generate-32+-random-hex-chars        # SECRET

# Encryption — encrypts stored SMTP credentials. SECRET. 64 hex chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NOTE: rotating this invalidates every already-encrypted SMTP credential, so
# accounts must be reconnected after a change.
ENCRYPTION_KEY=generate-64-hex-chars

# Stripe — required for billing/checkout. Both are SECRET.
# STRIPE_WEBHOOK_SECRET comes from the webhook endpoint you create in the Stripe
# dashboard pointing at {API_BASE_URL}/api/billing/webhook.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Vercel SMTP Relay (must match the values set in your Vercel project env vars)
SMTP_RELAY_URL=https://your-relay.vercel.app/api/send-email
SMTP_RELAY_SECRET=your-relay-secret                  # SECRET

# Client (VITE_ prefix required for Vite; baked into the browser bundle)
# Production: VITE_API_URL=https://api.usesincerely.com/api/v1
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://localhost:3001/api/v1
